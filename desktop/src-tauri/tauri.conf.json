{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenTracker",
  "version": "0.1.0",
  "identifier": "com.haileyliu.aiusagebar",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TokenTracker",
        "width": 340,
        "height": 520,
        "visible": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Cross-platform AI token usage monitor for macOS menu bar and Windows system tray.",
    "longDescription": "TokenTracker shows real Codex and Claude Code weekly usage, remaining percentage, reset time, and local seven-day token totals.",
    "copyright": "Copyright © 2026 Hailey Liu",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": null
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
